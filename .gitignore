# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
# Ignoramos TODO o /build/, EXCETO /build/web/, que vai versionado pro repo
# para que a Vercel consiga fazer auto-deploy estático a cada push.
/build/*
!/build/web/
/build/web/.last_build_id
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
.vercel

# Materiais de aula / referência das disciplinas (não fazem parte do código)
/IFRO/

# Memória de sessão do Claude Code
/memory/
